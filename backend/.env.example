# Copy to .env and fill in locally — never commit .env
#   cp .env.example .env

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://gradeops:gradeops@localhost:5432/gradeops

# JWT — generate a random string for local dev (mentor must set their own)
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Hugging Face — required for live VLM/OCR (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Set true to run pipeline without HF API calls (recommended for first local run)
PIPELINE_DRY_RUN=true

# Redis (Celery async grading)
REDIS_URL=redis://localhost:6379/0

# Storage: local (default) or s3
STORAGE_BACKEND=local
PUBLIC_BASE_URL=http://127.0.0.1:8000
# S3_BUCKET=
# S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_PUBLIC_BASE_URL=

# Optional overrides
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# HF_INFERENCE_URL=https://api-inference.huggingface.co
# CONSENSUS_SCORE_DELTA=1.0
# MAX_TRIBUNAL_ROUNDS=2
# UPLOAD_DIR=uploads
# CHROMA_PATH=data/chroma
