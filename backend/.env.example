# Copy to .env — never commit .env
#   cp .env.example .env
# Or run from repo root:  ./scripts/setup_database.sh

# Full URL (recommended). After setup_database.sh this matches Docker on port 5433.
DATABASE_URL=postgresql://gradeops:gradeops@localhost:5433/gradeops

# Or set components instead of DATABASE_URL (no defaults in Python — all required):
# POSTGRES_USER=gradeops
# POSTGRES_PASSWORD=gradeops
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_DB=gradeops

SECRET_KEY=replace-with-a-long-random-string
HF_TOKEN=
PIPELINE_DRY_RUN=true
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
PUBLIC_BASE_URL=http://127.0.0.1:8000
