# =============================================================================
# GradeOps — copy to .env (never commit .env)
#   cp .env.example .env
#
# Canonical database (matches docker-compose.yml):
#   user=gradeops  password=gradeops  db=gradeops  host=localhost  port=5432
# =============================================================================

# Docker Compose maps Postgres to host port 5433 (see docker-compose.yml)
DATABASE_URL=postgresql://gradeops:gradeops@localhost:5433/gradeops

# Optional overrides (usually leave unset; DATABASE_URL is built from these if unset)
# POSTGRES_USER=gradeops
# POSTGRES_PASSWORD=gradeops
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=gradeops

SECRET_KEY=change-me-to-a-long-random-string
HF_TOKEN=
PIPELINE_DRY_RUN=true
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
PUBLIC_BASE_URL=http://127.0.0.1:8000
